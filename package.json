{
  "name": "@as-integrations/koa",
  "description": "Apollo server integration for koa framework",
  "version": "1.1.1",
  "author": "Matt Gordon <matt@greenside.tech>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apollo-server-integrations/apollo-server-integration-koa.git"
  },
  "keywords": [
    "GraphQL",
    "Apollo",
    "Server",
    "Koa",
    "Javascript"
  ],
  "homepage": "https://github.com/apollo-server-integrations/apollo-server-integration-koa#readme",
  "bugs": {
    "url": "https://github.com/apollo-server-integrations/apollo-server-integration-koa/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=16.0"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "git clean -dfqX",
    "prepack": "npm run build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "publish-changeset": "changeset publish",
    "spell-check": "cspell lint '**' --no-progress || (echo 'Add any real words to cspell-dict.txt.'; exit 1)",
    "test": "jest",
    "test:ci": "jest --coverage --ci --maxWorkers=2 --reporters=default --reporters=jest-junit",
    "watch": "tsc --build --watch",
    "lint": "eslint src/**/*.ts"
  },
  "devDependencies": {
    "@apollo/server": "4.11.3",
    "@apollo/server-integration-testsuite": "4.11.3",
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.28.1",
    "@jest/globals": "29.7.0",
    "@jest/types": "30.4.1",
    "@koa/cors": "4.0.0",
    "@types/jest": "29.5.14",
    "@types/koa": "2.15.0",
    "@types/koa-bodyparser": "4.3.12",
    "@types/koa__cors": "4.0.3",
    "@types/node": "16.18.126",
    "@types/supertest": "2.0.16",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "cspell": "7.3.9",
    "eslint": "8.57.1",
    "graphql": "16.10.0",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "koa": "2.16.0",
    "koa-bodyparser": "4.4.1",
    "oxfmt": "^0.52.0",
    "supertest": "6.3.4",
    "ts-jest": "29.3.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  },
  "peerDependencies": {
    "@apollo/server": "^4.0.0",
    "koa": "^2.0.0"
  },
  "packageManager": "pnpm@11.4.0"
}
